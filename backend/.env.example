# ─── Local development only ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env or any real secrets.
#
# In production (AWS Lambda), the Anthropic API key is stored exclusively in
# AWS Systems Manager Parameter Store at the path below and is never set as
# a plain environment variable.

# Local dev shortcut: if set, the backend uses this directly and skips SSM.
# Unset (or leave blank) to use the real SSM path in production.
ANTHROPIC_API_KEY=sk-ant-...

# DynamoDB table name — matches the resource in template.yaml
DYNAMODB_TABLE_NAME=sentinelops-incidents

# AWS region
AWS_REGION=us-east-1

# SSM parameter path where the Anthropic key lives in production
SSM_API_KEY_PATH=/sentinelops/anthropic-api-key
